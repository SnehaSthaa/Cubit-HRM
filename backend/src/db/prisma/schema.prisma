generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  password_hash String
  name          String
  phone         String?
  role          UserRole[]
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  employee      Employee?
  reports       Report[]
  assets        Asset[]

  @@map("users")
}

model Employee {
  id                   String           @id @default(uuid()) @db.Uuid
  user_id              String           @unique @db.Uuid
  employee_id          String           @unique
  first_name           String
  last_name            String
  date_of_birth        DateTime?        @db.Date
  gender               String?
  phone                String?
  email                String           @unique
  department           String
  position             String?
  joining_date         DateTime         @db.Date
  salary               Decimal?         @db.Decimal(12, 2)
  manager_id           String?          @db.Uuid
  city                 String?
  state                String?
  postal_code          String?
  notes                String?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  account_number       String?
  bank_name            String?
  branch               String?
  contract_type        String?
  current_address      String?
  employment_status    EmploymentStatus @default(active)
  employment_type      String           @default("Full-time")
  father_name          String?
  grandfather_name     String?
  hierarchy            String?
  level                String?
  marital_status       String?
  profile_image        String?
  mother_name          String?
  permanent_address    String?
  previous_experience  String?
  citizenship_number   String?          @unique
  nid_number           String?          @unique
  pan_number           String?          @unique
  ssid_number          String?          @unique
  employee_verified    Boolean          @default(false)
  verification_pending Boolean          @default(false)

  assets            Asset[]            @relation("AssetAssignee")
  attendance        Attendance[]
  emergencyContacts EmergencyContact[]
  documents         EmployeeDocument[]
  manager           Employee?          @relation("EmployeeManager", fields: [manager_id], references: [id])
  subordinates      Employee[]         @relation("EmployeeManager")
  user              User               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  leaveBalances LeaveBalance[]
  leaves        Leave[]
  payroll       Payroll[]

  @@map("employees")
}

model EmergencyContact {
  id          String   @id @default(uuid()) @db.Uuid
  employee_id String   @db.Uuid
  name        String
  relation    String
  phone       String
  email       String?
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id])
  @@map("emergency_contacts")
}

model EmployeeDocument {
  id          String   @id @default(uuid()) @db.Uuid
  employee_id String   @db.Uuid
  name        String
  type        String
  status      String   @default("Pending")
  file_size   String?
  uploaded_at DateTime @default(now())
  file_url    String?
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id])
  @@map("employee_documents")
}

model Attendance {
  id          String           @id @default(uuid()) @db.Uuid
  employee_id String           @db.Uuid
  date        DateTime         @db.Date
  check_in    DateTime?        @db.Time(6)
  check_out   DateTime?        @db.Time(6)
  status      AttendanceStatus
  notes       String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  employee    Employee         @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, date])
  @@map("attendance")
}

model Leave {
  id             String      @id @default(uuid()) @db.Uuid
  employee_id    String      @db.Uuid
  start_date     DateTime    @db.Date
  end_date       DateTime    @db.Date
  leave_type_id  String      @db.Uuid
  days_count     Int
  reason         String?
  status         LeaveStatus @default(pending)
  approved_by    String?     @db.Uuid
  approval_notes String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  employee       Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leaveType      LeavePolicy @relation(fields: [leave_type_id], references: [id], onDelete: Cascade)

  @@map("leaves")
}

model Payroll {
  id          String        @id @default(uuid()) @db.Uuid
  employee_id String        @db.Uuid
  month       Int
  year        Int
  base_salary Decimal       @db.Decimal(12, 2)
  bonus       Decimal       @default(0) @db.Decimal(12, 2)
  deductions  Decimal       @default(0) @db.Decimal(12, 2)
  net_salary  Decimal       @db.Decimal(12, 2)
  status      PayrollStatus @default(pending)
  paid_date   DateTime?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  employee    Employee      @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, month, year])
  @@map("payroll")
}

model Asset {
  id            String      @id @default(uuid()) @db.Uuid
  asset_id      String      @unique
  name          String
  status        AssetStatus @default(available)
  category      String
  serial_number String?     @unique
  purchase_cost Decimal?    @db.Decimal(12, 2)
  purchase_date DateTime?   @db.Date
  assigned_date DateTime?   @db.Date
  location      String?
  notes         String?
  reason        String?
  return_date   DateTime?   @db.Date
  reveiwed_at   DateTime?

  assigned_to         String? @db.Uuid
  reviewed_by_user_id String? @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employee              Employee?            @relation("AssetAssignee", fields: [assigned_to], references: [id])
  reviewer              User?                @relation(fields: [reviewed_by_user_id], references: [id], onDelete: NoAction)
  assets_takehome_dates AssetsTakeHomeDate[]

  @@map("assets")
}

model AssetsTakeHomeDate {
  id         String         @id @default(uuid()) @db.Uuid
  status     TakeHomeStatus @default(pending)
  end_date   DateTime?      @db.Date
  start_date DateTime?      @db.Date
  reason     String?
  asset_id   String         @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  asset Asset @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@map("assets_takehome_dates")
}

model Report {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  type      ReportType
  from_date DateTime?  @db.Date
  to_date   DateTime?  @db.Date
  filters   Json?
  data      Json?

  generated_by String @db.Uuid

  created_at DateTime @default(now())

  user User @relation(fields: [generated_by], references: [id])

  @@map("reports")
}

model Holiday {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  start_date   DateTime    @db.Date
  end_date     DateTime    @db.Date
  holiday_type HolidayType @default(public)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@map("holidays")
}

model LeavePolicy {
  id                String         @id @default(uuid()) @db.Uuid
  name              String
  type              String         @unique
  annual_quota      Int
  pro_rata          Boolean        @default(false)
  carry_forward     Boolean        @default(false)
  max_carry_forward Int            @default(0)
  description       String?
  active            Boolean        @default(true)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  balances          LeaveBalance[]
  leaves            Leave[]

  @@map("leave_policies")
}

model LeaveBalance {
  id          String @id @default(uuid()) @db.Uuid
  employee_id String @db.Uuid
  year        Int

  leave_type_id String @db.Uuid

  used Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  total      Int      @default(0)

  employee    Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leavePolicy LeavePolicy @relation(fields: [leave_type_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, year, leave_type_id])
  @@map("leave_balances")
}

model Permission {
  id          Int      @id @default(autoincrement())
  role        UserRole
  permissions Json

  @@map("permissions")
}

enum UserRole {
  super_admin
  hr_admin
  employee
}

enum AttendanceStatus {
  present
  absent
  late
  half_day
  on_leave
}

enum LeaveStatus {
  pending
  approved
  rejected
}

enum TakeHomeStatus {
  pending
  approved
  rejected
}

enum PayrollStatus {
  pending
  processed
  paid
}

enum AssetStatus {
  available
  assigned
  maintenance
  retired
}

enum ReportType {
  attendance
  payroll
  leave
  performance
}

enum HolidayType {
  public
  company
  regional
  religious
}

enum EmploymentStatus {
  active
  notice_period
  resigned
}
