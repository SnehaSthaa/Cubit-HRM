generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  password_hash String
  name          String
  phone         String?
  role          UserRole
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  employee      Employee?
  reports       Report[]

  @@map("users")
}

model Employee {
  id                   String              @id @default(uuid()) @db.Uuid
  user_id              String              @unique @db.Uuid
  employee_id          String              @unique
  manager_id           String?             @db.Uuid
  notes                String?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt
  employee_verified    Boolean             @default(false)
  profile_image        String?
  verification_pending Boolean             @default(false)
  assets               Asset[]             @relation("AssetAssignee")
  attendance           Attendance[]
  attendance_requests  AttendanceRequest[]
  bank_details         BankDetail?
  department           Department[]
  deviceMappings       DeviceMapping[]
  emergencyContacts    EmergencyContact[]
  documents            EmployeeDocument[]
  manager              Employee?           @relation("EmployeeManager", fields: [manager_id], references: [id])
  subordinates         Employee[]          @relation("EmployeeManager")
  user                 User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  leaveBalances        LeaveBalance[]
  leaves               Leave[]
  payroll              Payroll[]
  personal_details     PersonalDetail?

  @@map("employees")
}

model Department {
  id                  String   @id @default(uuid()) @db.Uuid
  employee_id         String   @db.Uuid
  department_name     String
  hierarchy           String?
  joining_date        DateTime @db.Date
  previous_experience String?
  employment_type     String?
  employment_status   String?
  designation         String?
  level               String?
  employee            Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("departments")
}

model PersonalDetail {
  id                 String            @id @default(uuid()) @db.Uuid
  employee_id        String            @unique @db.Uuid
  first_name         String
  last_name          String
  email              String            @unique
  phone              String?           @unique
  date_of_birth      DateTime?         @db.Date
  gender             String?
  marital_status     String?
  citizenship_number String?           @unique
  pan_number         String?           @unique
  nid_number         String?           @unique
  ssid_number        String?           @unique
  father_name        String?
  mother_name        String?
  grandfather_name   String?
  current_address    String?
  permanent_address  String?
  country            String?
  state              String?
  district           String?
  city               String?
  municipality       MunicipalityType?
  ward               Int?
  tole               String?
  employee           Employee          @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("personal_details")
}

model BankDetail {
  id             String   @id @default(uuid()) @db.Uuid
  employee_id    String   @unique @db.Uuid
  account_number String
  salary         Decimal  @db.Decimal(12, 2)
  bank_name      String
  branch         String
  contract_type  String?
  employee       Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("bank_details")
}

model EmergencyContact {
  id          String   @id @default(uuid()) @db.Uuid
  employee_id String   @db.Uuid
  name        String
  relation    String
  phone       String
  email       String?
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id])
  @@map("emergency_contacts")
}

model EmployeeDocument {
  id          String   @id @default(uuid()) @db.Uuid
  employee_id String   @db.Uuid
  name        String
  type        String
  status      String   @default("Pending")
  file_size   String?
  uploaded_at DateTime @default(now())
  file_url    String?
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id])
  @@map("employee_documents")
}

model Attendance {
  id           String           @id @default(uuid()) @db.Uuid
  employee_id  String           @db.Uuid
  date         DateTime         @db.Date
  status       AttendanceStatus
  notes        String?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  deviceId     String?
  check_in     DateTime?        @db.Timestamptz
  check_out    DateTime?        @db.Timestamptz
  biometric_id String?
  device       Device?          @relation(fields: [deviceId], references: [serial_number])
  employee     Employee         @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, date])
  @@map("attendance")
}

model AttendanceRequest {
  id          String   @id @default(uuid()) @db.Uuid
  employee_id String   @db.Uuid
  date        DateTime @db.Date

  request_type        AttendanceRequestType
  requested_check_in  DateTime?             @db.Timestamptz
  requested_check_out DateTime?             @db.Timestamptz
  requested_status    AttendanceStatus?

  reason String

  status         AttendanceRequestStatus @default(pending)
  reviewed_by    String?                 @db.Uuid
  reviewed_at    DateTime?
  reviewer_notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id])
  @@index([status])
  @@map("attendance_requests")
}

model Device {
  id            String          @id @default(uuid()) @db.Uuid
  serial_number String          @unique
  location      String?
  device_name   String
  device_model  String
  ip            String          @unique
  is_active     Boolean         @default(true)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  attendances   Attendance[]
  mappings      DeviceMapping[]

  @@map("devices")
}

model DeviceMapping {
  id           String   @id @default(uuid()) @db.Uuid
  employee_id  String   @db.Uuid
  device_id    String   @db.Uuid
  biometric_id String   @unique
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  device       Device   @relation(fields: [device_id], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([device_id, biometric_id])
  @@unique([employee_id, device_id])
  @@map("device_mappings")
}

model Leave {
  id             String      @id @default(uuid()) @db.Uuid
  employee_id    String      @db.Uuid
  start_date     DateTime    @db.Date
  end_date       DateTime    @db.Date
  days_count     Int
  reason         String?
  status         LeaveStatus @default(pending)
  approved_by    String?     @db.Uuid
  approval_notes String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  leave_type_id  String      @db.Uuid
  employee       Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leaveType      LeavePolicy @relation(fields: [leave_type_id], references: [id])

  @@map("leaves")
}

model Payroll {
  id          String        @id @default(uuid()) @db.Uuid
  employee_id String        @db.Uuid
  month       Int
  year        Int
  base_salary Decimal       @db.Decimal(12, 2)
  bonus       Decimal       @default(0) @db.Decimal(12, 2)
  deductions  Decimal       @default(0) @db.Decimal(12, 2)
  net_salary  Decimal       @db.Decimal(12, 2)
  status      PayrollStatus @default(pending)
  paid_date   DateTime?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  employee    Employee      @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, month, year])
  @@map("payroll")
}

model Asset {
  id            String      @id @default(uuid()) @db.Uuid
  asset_id      String      @unique
  name          String
  category      String
  serial_number String?     @unique
  purchase_cost Decimal?    @db.Decimal(12, 2)
  purchase_date DateTime?   @db.Date
  status        AssetStatus @default(available)
  assigned_to   String?     @db.Uuid
  assigned_date DateTime?   @db.Date
  location      String?
  notes         String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  return_date   DateTime?   @db.Date
  employee      Employee?   @relation("AssetAssignee", fields: [assigned_to], references: [id])

  @@map("assets")
}

model Report {
  id           String     @id @default(uuid()) @db.Uuid
  generated_by String     @db.Uuid
  name         String
  type         ReportType
  from_date    DateTime?  @db.Date
  to_date      DateTime?  @db.Date
  filters      Json?
  data         Json?
  created_at   DateTime   @default(now())
  user         User       @relation(fields: [generated_by], references: [id])

  @@map("reports")
}

model Holiday {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  start_date   DateTime    @db.Date
  end_date     DateTime    @db.Date
  holiday_type HolidayType @default(public)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@map("holidays")
}

model LeavePolicy {
  id                String         @id @default(uuid()) @db.Uuid
  name              String
  type              String         @unique
  annual_quota      Int
  pro_rata          Boolean        @default(false)
  carry_forward     Boolean        @default(false)
  max_carry_forward Int            @default(0)
  description       String?
  active            Boolean        @default(true)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  balances          LeaveBalance[]
  leaves            Leave[]

  @@map("leave_policies")
}

model LeaveBalance {
  id            String      @id @default(uuid()) @db.Uuid
  employee_id   String      @db.Uuid
  year          Int
  leave_type_id String      @db.Uuid
  used          Int         @default(0)
  remaining     Int         @default(0)
  total         Int         @default(0)
  leavePolicyId String?     @db.Uuid
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  employee      Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leavePolicy   LeavePolicy @relation(fields: [leave_type_id], references: [id])

  @@unique([employee_id, year, leave_type_id])
  @@map("leave_balances")
}

enum UserRole {
  super_admin
  hr_admin
  employee
}

enum AttendanceStatus {
  present
  absent
  late
  half_day
  on_leave
}

enum AttendanceRequestType {
  check_in
  check_out
  both
}

enum AttendanceRequestStatus {
  pending
  approved
  rejected
}

enum LeaveStatus {
  pending
  approved
  rejected
}

enum PayrollStatus {
  pending
  processed
  paid
}

enum AssetStatus {
  available
  assigned
  maintenance
  retired
}

enum ReportType {
  attendance
  payroll
  leave
  performance
}

enum HolidayType {
  public
  company
  regional
  religious
}

enum MunicipalityType {
  metropolitian
  sub_metropolitian
  municipality
  rural_municipality
}
